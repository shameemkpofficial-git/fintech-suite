import React from 'react';
import { render, fireEvent } from '@testing-library/react-native';
import { BaseInputField, InputField } from '../InputField';
import { componentRegistry } from '../ComponentRegistry';
import { Text } from 'react-native';

describe('InputField', () => {
  describe('BaseInputField', () => {
    it('renders the label correctly', () => {
      const { getByText } = render(<BaseInputField label="Username" />);
      expect(getByText('Username')).toBeTruthy();
    });

    it('renders the placeholder text', () => {
      const { getByPlaceholderText } = render(
        <BaseInputField label="Email" placeholder="Enter your email" />
      );
      expect(getByPlaceholderText('Enter your email')).toBeTruthy();
    });

    it('handles onChangeText when the text changes', () => {
      const onChangeTextMock = jest.fn();
      const { getByPlaceholderText } = render(
        <BaseInputField label="Search" placeholder="Search..." onChangeText={onChangeTextMock} />
      );
      
      fireEvent.changeText(getByPlaceholderText('Search...'), 'hello');
      expect(onChangeTextMock).toHaveBeenCalledWith('hello');
    });

    it('displays an icon when provided', () => {
      // Since Ionicons is mocked as a View in jest-setup.js with props
      const { getByTestId } = render(
        <BaseInputField label="Password" icon="lock-closed" testID="input-view" />
      );
      
      // We can check if the input is rendered
      expect(getByTestId('input-view')).toBeTruthy();
    });
  });

  describe('Registry-aware InputField', () => {
    it('resolves the default BaseInputField when no override is registered', () => {
      const { getByText } = render(<InputField label="Registry" />);
      expect(getByText('Registry')).toBeTruthy();
    });

    it('uses the custom implementation when registered', () => {
      const CustomInput = ({ label }: { label: string }) => <Text>Custom {label}</Text>;
      
      // Save current mapping
      const original = componentRegistry.resolve('InputField');
      
      componentRegistry.register({ InputField: CustomInput as any });
      const { getByText, unmount } = render(<InputField label="Field" />);
      
      expect(getByText('Custom Field')).toBeTruthy();
      
      // Cleanup: Restore original
      componentRegistry.register({ InputField: original });
      unmount();
    });
  });
});
